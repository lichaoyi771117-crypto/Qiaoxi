# Qiaoxi Contract-Analyzer 环境变量配置
# 本文件为示例，真实凭证请通过环境变量或部署平台密钥管理注入，不要写入真实值后提交。

# DeepSeek API 配置（必填）
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 可选：自定义 LLM 调用超时（秒），默认 120
# LLM_TIMEOUT_SECONDS=120

# Qiaoxi 中间态数据 AES-256 加密密钥（留空则明文存储，不建议生产环境留空）
QIAOXI_ENCRYPTION_KEY=

# Streamlit 运行配置（可选）
# STREAMLIT_SERVER_HEADLESS=true
